
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}
model User { 
  id    Int     @id @default(autoincrement()) 
  email String  @unique
  name  String
  image String
  quotes Quote[]
} 
model Quote { 
  id        Int     @id @default(autoincrement()) 
  title String
  author    User    @relation(fields: [authorId], references: [id]) 
  authorId  Int
} 